# ── LLM ──────────────────────────────────────────────────────────
# Leave empty to run in MOCK mode (no key needed, heuristic grading).
# Add your key to enable real Claude Socratic questioning + grading.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5

# ── Prototype conveniences ───────────────────────────────────────
# "true" lets you complete many sessions per day (for testing).
# Set to "false" to enforce the real one-session-per-day rule.
DEV_UNLIMITED_SESSIONS=true
